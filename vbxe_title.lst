mads 2.1.8
vbxe_title.asm -o:vbxe_title.xex -l 
Source: vbxe_title.asm
     1 				; VBXE Title Screen - XCOLOR palette remap.
     2 				; Fills all 256 palette entries: 0=black, 1-255=cyan.
     3 				; This way any COLPF value the game's DLI sets maps
     4 				; to either black (background) or cyan (foreground).
     5 				; No ANTIC changes needed. One-shot VBI hook.
     6
     7 = D640			VBXE_VC   = $D640
     8 = D644			VBXE_CSEL = $D644
     9 = D645			VBXE_PSEL = $D645
    10 = D646			VBXE_CR   = $D646
    11 = D647			VBXE_CG   = $D647
    12 = D648			VBXE_CB   = $D648
    13
    14 = 022F			SDMCTL    = $022F
    15 = 0222			VVBLKI    = $0222
    16
    17 = 05B9			GAME_ENTRY = $05B9
    18 = 0BD6			GAME_VBI   = $0BD6
    19 = BC1A			RELOC_JMP  = $BC1A
    20 = 0BBF			HOOK_ADDR  = $0BBF
    21 = 0B81			HOOK_CONT  = $0B81
    22
    23 				        org $0400
    24
    25 				; --- INIT (XEX load time) ---
    26 FFFF> 0400-0467> A9 0B	init    lda #<postrel
    27 0402 8D 1B BC		        sta RELOC_JMP+1
    28 0405 A9 04		        lda #>postrel
    29 0407 8D 1C BC		        sta RELOC_JMP+2
    30 040A 60			        rts
    31
    32 				; --- POST-RELOC ---
    33 040B A9 4C		postrel lda #$4C
    34 040D 8D BF 0B		        sta HOOK_ADDR
    35 0410 A9 1D		        lda #<tsetup
    36 0412 8D C0 0B		        sta HOOK_ADDR+1
    37 0415 A9 04		        lda #>tsetup
    38 0417 8D C1 0B		        sta HOOK_ADDR+2
    39 041A 4C B9 05		        jmp GAME_ENTRY
    40
    41 				; --- TITLE SETUP ---
    42 041D 78			tsetup  sei
    43 041E A9 31		        lda #<vbihook
    44 0420 8D 22 02		        sta VVBLKI
    45 0423 A9 04		        lda #>vbihook
    46 0425 8D 23 02		        sta VVBLKI+1
    47 0428 A9 3A		        lda #$3A
    48 042A 8D 2F 02		        sta SDMCTL
    49 042D 58			        cli
    50 042E 4C 81 0B		        jmp HOOK_CONT
    51
    52 				; --- VBI HOOK (one-shot) ---
    53 0431			vbihook
    54 				        ; Palette page 0, entry 0 = black
    55 0431 A9 00		        lda #0
    56 0433 8D 45 D6		        sta VBXE_PSEL
    57 0436 8D 44 D6		        sta VBXE_CSEL
    58 0439 8D 46 D6		        sta VBXE_CR
    59 043C 8D 47 D6		        sta VBXE_CG
    60 043F 8D 48 D6		        sta VBXE_CB          ; CSEL auto-advances to 1
    61
    62 				        ; Fill entries 1-255 with C64 cyan
    63 0442 A2 FF		        ldx #255
    64 0444 A9 6A		fill    lda #106
    65 0446 8D 46 D6		        sta VBXE_CR
    66 0449 A9 BF		        lda #191
    67 044B 8D 47 D6		        sta VBXE_CG
    68 044E A9 C6		        lda #198
    69 0450 8D 48 D6		        sta VBXE_CB          ; auto-advance
    70 0453 CA			        dex
    71 0454 D0 EE		        bne fill
    72
    73 				        ; Enable XCOLOR
    74 0456 A9 01		        lda #$01
    75 0458 8D 40 D6		        sta VBXE_VC
    76
    77 				        ; Unhook → game VBI
    78 045B A9 D6		        lda #<GAME_VBI
    79 045D 8D 22 02		        sta VVBLKI
    80 0460 A9 0B		        lda #>GAME_VBI
    81 0462 8D 23 02		        sta VVBLKI+1
    82
    83 0465 4C D6 0B		        jmp GAME_VBI
    84
    85 				        .if * > $0580
    86 				        .error "Too large!"
    87 				        .endif
    88
    89 0468			        org $02E2
    90 02E2-02E3> 00 04		        .word init
