mads 2.1.8
src/vbxe_init.asm -o:build/vbxe_init.xex -l:build/vbxe_init.lst 
Source: vbxe_init.asm
     1 				; ============================================================
     2 				; VBXE Title Screen Colour Enhancement for Starquake
     3 				; Assembled with MADS assembler
     4 				;
     5 				; Remaps the VBXE palette so that the Atari's grayscale
     6 				; colour entries ($00-$0E) become a blue gradient instead
     7 				; of black-to-white.  This turns the B&W title screen into
     8 				; a C64-style "cyan-on-navy" look.
     9 				;
    10 				; Loaded at $0480 (safe from the game's $0600-$0FFF decrypt).
    11 				; Runs once via INITAD, then can be overwritten.
    12 				; ============================================================
    13
    14 				; --- VBXE registers (base $D640) ---
    15 = D640			VBXE        = $D640
    16 = D640			VCTL        = VBXE+$00   ; VIDEO_CONTROL (read: core version)
    17 = D644			CSEL        = VBXE+$04   ; Colour register select
    18 = D645			PSEL        = VBXE+$05   ; Palette select
    19 = D646			CR          = VBXE+$06   ; Red   (0-127)
    20 = D647			CG          = VBXE+$07   ; Green (0-127)
    21 = D648			CB          = VBXE+$08   ; Blue  (0-127)
    22
    23 				; ============================================================
    24 				        org $0480
    25 				; ============================================================
    26 				vbxe_init:
    27 				        ; --- Detect VBXE ---
    28 				        ; $D640 returns core version ($1x for FX) on VBXE,
    29 				        ; open-bus / $FF on stock hardware.
    30 FFFF> 0480-0633> AD 40 +         lda VCTL
    31 0483 29 F0		        and #$F0
    32 0485 C9 10		        cmp #$10
    33 0487 F0 01		        beq detected
    34 0489 60			        rts
    35 048A			detected:
    36
    37 				        ; Select palette 0 (the default playfield palette).
    38 048A A9 00		        lda #$00
    39 048C 8D 45 D6		        sta PSEL
    40
    41 				        ; ------------------------------------------------
    42 				        ; Remap grayscale entries ($00,$02,...,$0E).
    43 				        ; Original: black → white.
    44 				        ; New:      dark navy → light cyan (C64 feel).
    45 				        ; ------------------------------------------------
    46
    47 				        ; $00 — was black → now dark navy
    48 048F A9 00		        lda #$00
    49 0491 8D 44 D6		        sta CSEL
    50 0494 A9 05		        lda #5
    51 0496 8D 46 D6		        sta CR
    52 0499 A9 05		        lda #5
    53 049B 8D 47 D6		        sta CG
    54 049E A9 20		        lda #32
    55 04A0 8D 48 D6		        sta CB
    56
    57 				        ; $02
    58 04A3 A9 02		        lda #$02
    59 04A5 8D 44 D6		        sta CSEL
    60 04A8 A9 08		        lda #8
    61 04AA 8D 46 D6		        sta CR
    62 04AD A9 0A		        lda #10
    63 04AF 8D 47 D6		        sta CG
    64 04B2 A9 2A		        lda #42
    65 04B4 8D 48 D6		        sta CB
    66
    67 				        ; $04
    68 04B7 A9 04		        lda #$04
    69 04B9 8D 44 D6		        sta CSEL
    70 04BC A9 0C		        lda #12
    71 04BE 8D 46 D6		        sta CR
    72 04C1 A9 10		        lda #16
    73 04C3 8D 47 D6		        sta CG
    74 04C6 A9 34		        lda #52
    75 04C8 8D 48 D6		        sta CB
    76
    77 				        ; $06
    78 04CB A9 06		        lda #$06
    79 04CD 8D 44 D6		        sta CSEL
    80 04D0 A9 12		        lda #18
    81 04D2 8D 46 D6		        sta CR
    82 04D5 A9 18		        lda #24
    83 04D7 8D 47 D6		        sta CG
    84 04DA A9 3E		        lda #62
    85 04DC 8D 48 D6		        sta CB
    86
    87 				        ; $08
    88 04DF A9 08		        lda #$08
    89 04E1 8D 44 D6		        sta CSEL
    90 04E4 A9 1A		        lda #26
    91 04E6 8D 46 D6		        sta CR
    92 04E9 A9 22		        lda #34
    93 04EB 8D 47 D6		        sta CG
    94 04EE A9 48		        lda #72
    95 04F0 8D 48 D6		        sta CB
    96
    97 				        ; $0A
    98 04F3 A9 0A		        lda #$0A
    99 04F5 8D 44 D6		        sta CSEL
   100 04F8 A9 26		        lda #38
   101 04FA 8D 46 D6		        sta CR
   102 04FD A9 30		        lda #48
   103 04FF 8D 47 D6		        sta CG
   104 0502 A9 54		        lda #84
   105 0504 8D 48 D6		        sta CB
   106
   107 				        ; $0C
   108 0507 A9 0C		        lda #$0C
   109 0509 8D 44 D6		        sta CSEL
   110 050C A9 37		        lda #55
   111 050E 8D 46 D6		        sta CR
   112 0511 A9 44		        lda #68
   113 0513 8D 47 D6		        sta CG
   114 0516 A9 62		        lda #98
   115 0518 8D 48 D6		        sta CB
   116
   117 				        ; $0E — was white → now bright cyan
   118 051B A9 0E		        lda #$0E
   119 051D 8D 44 D6		        sta CSEL
   120 0520 A9 4B		        lda #75
   121 0522 8D 46 D6		        sta CR
   122 0525 A9 5F		        lda #95
   123 0527 8D 47 D6		        sta CG
   124 052A A9 73		        lda #115
   125 052C 8D 48 D6		        sta CB
   126
   127 				        ; ------------------------------------------------
   128 				        ; Also remap blue-range entries the game may use
   129 				        ; so the in-game colours look more C64-like.
   130 				        ; ------------------------------------------------
   131
   132 				        ; $90 — dark blue
   133 052F A9 90		        lda #$90
   134 0531 8D 44 D6		        sta CSEL
   135 0534 A9 0A		        lda #10
   136 0536 8D 46 D6		        sta CR
   137 0539 A9 08		        lda #8
   138 053B 8D 47 D6		        sta CG
   139 053E A9 2D		        lda #45
   140 0540 8D 48 D6		        sta CB
   141
   142 				        ; $92 — blue
   143 0543 A9 92		        lda #$92
   144 0545 8D 44 D6		        sta CSEL
   145 0548 A9 10		        lda #16
   146 054A 8D 46 D6		        sta CR
   147 054D A9 0E		        lda #14
   148 054F 8D 47 D6		        sta CG
   149 0552 A9 37		        lda #55
   150 0554 8D 48 D6		        sta CB
   151
   152 				        ; $94 — blue (standard Atari bg blue)
   153 0557 A9 94		        lda #$94
   154 0559 8D 44 D6		        sta CSEL
   155 055C A9 1A		        lda #26
   156 055E 8D 46 D6		        sta CR
   157 0561 A9 14		        lda #20
   158 0563 8D 47 D6		        sta CG
   159 0566 A9 3C		        lda #60
   160 0568 8D 48 D6		        sta CB
   161
   162 				        ; $96
   163 056B A9 96		        lda #$96
   164 056D 8D 44 D6		        sta CSEL
   165 0570 A9 20		        lda #32
   166 0572 8D 46 D6		        sta CR
   167 0575 A9 1C		        lda #28
   168 0577 8D 47 D6		        sta CG
   169 057A A9 48		        lda #72
   170 057C 8D 48 D6		        sta CB
   171
   172 				        ; $98
   173 057F A9 98		        lda #$98
   174 0581 8D 44 D6		        sta CSEL
   175 0584 A9 28		        lda #40
   176 0586 8D 46 D6		        sta CR
   177 0589 A9 26		        lda #38
   178 058B 8D 47 D6		        sta CG
   179 058E A9 50		        lda #80
   180 0590 8D 48 D6		        sta CB
   181
   182 				        ; $9A
   183 0593 A9 9A		        lda #$9A
   184 0595 8D 44 D6		        sta CSEL
   185 0598 A9 32		        lda #50
   186 059A 8D 46 D6		        sta CR
   187 059D A9 32		        lda #50
   188 059F 8D 47 D6		        sta CG
   189 05A2 A9 5C		        lda #92
   190 05A4 8D 48 D6		        sta CB
   191
   192 				        ; $9C
   193 05A7 A9 9C		        lda #$9C
   194 05A9 8D 44 D6		        sta CSEL
   195 05AC A9 3E		        lda #62
   196 05AE 8D 46 D6		        sta CR
   197 05B1 A9 40		        lda #64
   198 05B3 8D 47 D6		        sta CG
   199 05B6 A9 66		        lda #102
   200 05B8 8D 48 D6		        sta CB
   201
   202 				        ; $9E — bright blue
   203 05BB A9 9E		        lda #$9E
   204 05BD 8D 44 D6		        sta CSEL
   205 05C0 A9 4E		        lda #78
   206 05C2 8D 46 D6		        sta CR
   207 05C5 A9 50		        lda #80
   208 05C7 8D 47 D6		        sta CG
   209 05CA A9 73		        lda #115
   210 05CC 8D 48 D6		        sta CB
   211
   212 				        ; ------------------------------------------------
   213 				        ; Purple/violet range ($5x) for gradient effects
   214 				        ; ------------------------------------------------
   215
   216 				        ; $56 — purple
   217 05CF A9 56		        lda #$56
   218 05D1 8D 44 D6		        sta CSEL
   219 05D4 A9 32		        lda #50
   220 05D6 8D 46 D6		        sta CR
   221 05D9 A9 12		        lda #18
   222 05DB 8D 47 D6		        sta CG
   223 05DE A9 3E		        lda #62
   224 05E0 8D 48 D6		        sta CB
   225
   226 				        ; $58
   227 05E3 A9 58		        lda #$58
   228 05E5 8D 44 D6		        sta CSEL
   229 05E8 A9 3C		        lda #60
   230 05EA 8D 46 D6		        sta CR
   231 05ED A9 1C		        lda #28
   232 05EF 8D 47 D6		        sta CG
   233 05F2 A9 4B		        lda #75
   234 05F4 8D 48 D6		        sta CB
   235
   236 				        ; ------------------------------------------------
   237 				        ; Cyan range ($Ax) for highlights
   238 				        ; ------------------------------------------------
   239
   240 				        ; $AA — cyan
   241 05F7 A9 AA		        lda #$AA
   242 05F9 8D 44 D6		        sta CSEL
   243 05FC A9 12		        lda #18
   244 05FE 8D 46 D6		        sta CR
   245 0601 A9 44		        lda #68
   246 0603 8D 47 D6		        sta CG
   247 0606 A9 4E		        lda #78
   248 0608 8D 48 D6		        sta CB
   249
   250 				        ; $AC
   251 060B A9 AC		        lda #$AC
   252 060D 8D 44 D6		        sta CSEL
   253 0610 A9 1E		        lda #30
   254 0612 8D 46 D6		        sta CR
   255 0615 A9 52		        lda #82
   256 0617 8D 47 D6		        sta CG
   257 061A A9 55		        lda #85
   258 061C 8D 48 D6		        sta CB
   259
   260 				        ; $AE
   261 061F A9 AE		        lda #$AE
   262 0621 8D 44 D6		        sta CSEL
   263 0624 A9 30		        lda #48
   264 0626 8D 46 D6		        sta CR
   265 0629 A9 62		        lda #98
   266 062B 8D 47 D6		        sta CG
   267 062E A9 5F		        lda #95
   268 0630 8D 48 D6		        sta CB
   269
   270 0633 60			        rts
   271
   272 				; ============================================================
   273 				; INITAD trigger — loaded at $02E2 to call vbxe_init
   274 				; ============================================================
   275 0634			        org $02E2
   276 02E2-02E3> 80 04		        .word vbxe_init
