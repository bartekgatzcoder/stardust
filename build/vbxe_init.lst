mads 2.1.8
src/vbxe_init.asm -o:build/vbxe_init.xex -l:build/vbxe_init.lst 
Source: vbxe_init.asm
     1 				; ============================================================
     2 				; VBXE test — minimal overlay following st2vbxe approach.
     3 				;
     4 				; st2vbxe by Piotr Fusik (pfusik) is a working VBXE viewer.
     5 				; This code mirrors its exact register/XDL setup:
     6 				;
     7 				;  - MEMAC-B ($D65D) for VRAM access (NOT MEMAC-A)
     8 				;  - XDL at VRAM $10000 (bank 4)
     9 				;  - Overlay bitmap at VRAM $10100
    10 				;  - VIDEO_CONTROL = $05 (xdl_enabled | no_trans)
    11 				;  - XDL: 20 blank + 200 lines GMON overlay, step=320
    12 				;  - Palette written via indirect (fx_ptr),Y addressing
    13 				;
    14 				; Fills the overlay with colour bands to prove VBXE works.
    15 				; ============================================================
    16
    17 				; VRAM addresses (matching st2vbxe)
    18 = 010000			xdl_vbxe    = $10000
    19 = 010100			scr_vbxe    = $10100
    20
    21 				; Zero page
    22 = 00E0			fx_ptr      = $E0       ; 2 bytes — pointer to $D600 or $D700
    23 = 00E2			zptr        = $E2       ; 2 bytes — VRAM write pointer
    24
    25 				; ============================================================
    26 				        org $0480
    27 				; ============================================================
    28 				vbxe_init:
    29 				        ; --- Detect VBXE (matches st2vbxe fx_detect) ---
    30 FFFF> 0480-05B9> A9 00	        lda #<$D600
    31 0482 85 E0		        sta fx_ptr
    32 0484 A9 D6		        lda #>$D600
    33 0486 85 E1		        sta fx_ptr+1
    34 0488 20 95 04		        jsr fx_try
    35 048B F0 0F		        beq found
    36 048D E6 E1		        inc fx_ptr+1       ; try $D700
    37 048F 20 95 04		        jsr fx_try
    38 0492 F0 08		        beq found
    39 0494 60			        rts                ; no VBXE
    40 0495 A0 40		fx_try: ldy #$40           ; CORE_VERSION
    41 0497 B1 E0		        lda (fx_ptr),y
    42 0499 C9 10		        cmp #$10           ; FX 1.xx?
    43 049B 60			        rts
    44 049C			found:
    45
    46 				        ; --- Map MEMAC-B to bank 4 ---
    47 				        ; VRAM $10000-$13FFF → CPU $4000-$7FFF
    48 				        ; Bank = $10000 >> 14 = 4.  Enable = $80.
    49 049C A0 5D		        ldy #$5D            ; FX_MEMB
    50 049E A9 84		        lda #$84            ; $80 | 4
    51 04A0 91 E0		        sta (fx_ptr),y
    52
    53 				        ; --- Copy XDL to VRAM $10000 = CPU $4000 ---
    54 04A2 A0 0A		        ldy #xdl_len-1
    55 04A4 B9 AF 05		cpxdl:  lda xdl,y
    56 04A7 99 00 40		        sta $4000,y
    57 04AA 88			        dey
    58 04AB 10 F7		        bpl cpxdl
    59
    60 				        ; --- Fill overlay bitmap ---
    61 				        ; VRAM $10100 = CPU $4100.
    62 				        ; Fill ~48 pages (12288 bytes ≈ 38 rows of 320px).
    63 				        ; Colour = (page / 6) + 1, giving bands of entries 1-8.
    64 04AD A9 00		        lda #<$4100
    65 04AF 85 E2		        sta zptr
    66 04B1 A9 41		        lda #>$4100
    67 04B3 85 E3		        sta zptr+1
    68
    69 04B5 A2 00		        ldx #0              ; page counter
    70 04B7 8A			fillpg: txa
    71 04B8 4A			        lsr
    72 04B9 4A			        lsr                 ; /4 → gives ~8 colour bands
    73 04BA 18			        clc
    74 04BB 69 01		        adc #1              ; palette entries 1-13
    75 04BD A0 00		        ldy #0
    76 04BF 91 E2		fillby: sta (zptr),y
    77 04C1 C8			        iny
    78 04C2 D0 FB		        bne fillby
    79 04C4 E6 E3		        inc zptr+1
    80 04C6 E8			        inx
    81 04C7 E0 30		        cpx #48             ; 48 pages ≈ 38 rows
    82 04C9 D0 EC		        bne fillpg
    83
    84 				        ; --- Unmap MEMAC-B ---
    85 04CB A0 5D		        ldy #$5D
    86 04CD A9 00		        lda #0
    87 04CF 91 E0		        sta (fx_ptr),y
    88
    89 				        ; --- Set palette (palette 0, entries 0-13) ---
    90 04D1 A0 44		        ldy #$44            ; FX_CSEL
    91 04D3 A9 00		        lda #0
    92 04D5 91 E0		        sta (fx_ptr),y
    93 04D7 C8			        iny                 ; FX_PSEL ($45)
    94 04D8 A9 00		        lda #0              ; palette 0
    95 04DA 91 E0		        sta (fx_ptr),y
    96
    97 				        ; Entry 0: dark navy background
    98 04DC 20 38 05		        jsr pal_0_5_5_35
    99
   100 				        ; Entry 1: deep purple
   101 04DF A0 46		        ldy #$46
   102 04E1 A9 32		        lda #50
   103 04E3 91 E0		        sta (fx_ptr),y
   104 04E5 C8			        iny
   105 04E6 A9 0A		        lda #10
   106 04E8 91 E0		        sta (fx_ptr),y
   107 04EA C8			        iny
   108 04EB A9 3C		        lda #60
   109 04ED 91 E0		        sta (fx_ptr),y
   110
   111 				        ; Entry 2: purple-blue
   112 04EF 20 49 05		        jsr pal_40_20_75
   113
   114 				        ; Entry 3: blue
   115 04F2 20 5A 05		        jsr pal_25_35_90
   116
   117 				        ; Entry 4: cyan-blue
   118 04F5 20 6B 05		        jsr pal_20_55_95
   119
   120 				        ; Entry 5: teal
   121 04F8 20 7C 05		        jsr pal_15_65_80
   122
   123 				        ; Entry 6: cyan
   124 04FB 20 8D 05		        jsr pal_20_80_80
   125
   126 				        ; Entry 7: bright cyan
   127 04FE 20 9E 05		        jsr pal_40_95_90
   128
   129 				        ; Entry 8: white-cyan
   130 0501 A0 46		        ldy #$46
   131 0503 A9 41		        lda #65
   132 0505 91 E0		        sta (fx_ptr),y
   133 0507 C8			        iny
   134 0508 A9 69		        lda #105
   135 050A 91 E0		        sta (fx_ptr),y
   136 050C C8			        iny
   137 050D A9 6E		        lda #110
   138 050F 91 E0		        sta (fx_ptr),y
   139
   140 				        ; Entries 9-13: repeat bright tones
   141 0511 20 9E 05		        jsr pal_40_95_90
   142 0514 20 8D 05		        jsr pal_20_80_80
   143 0517 20 7C 05		        jsr pal_15_65_80
   144 051A 20 6B 05		        jsr pal_20_55_95
   145 051D 20 5A 05		        jsr pal_25_35_90
   146
   147 				        ; --- Enable VBXE display ---
   148 				        ; (Matches st2vbxe setup_vbxe)
   149 0520 A0 40		        ldy #$40            ; VIDEO_CONTROL
   150 0522 A9 05		        lda #$05            ; xdl_enabled | no_trans
   151 0524 91 E0		        sta (fx_ptr),y
   152 0526 C8			        iny                 ; XDL_ADR0
   153 0527 A9 00		        lda #<[xdl_vbxe]
   154 0529 91 E0		        sta (fx_ptr),y
   155 052B C8			        iny                 ; XDL_ADR1
   156 052C A9 00		        lda #>[xdl_vbxe]
   157 052E 91 E0		        sta (fx_ptr),y
   158 0530 C8			        iny                 ; XDL_ADR2
   159 0531 A9 00		        lda #0              ; xdl_vbxe >> 16 = 1, but >>16 of $10000 = 1
   160 0533 09 01		        ora #1
   161 0535 91 E0		        sta (fx_ptr),y
   162
   163 0537 60			        rts
   164
   165 				; --- Palette helper subroutines (auto-advance CSEL) ---
   166 0538			pal_0_5_5_35:
   167 0538 A0 46		        ldy #$46
   168 053A A9 05		        lda #5
   169 053C 91 E0		        sta (fx_ptr),y
   170 053E C8			        iny
   171 053F A9 05		        lda #5
   172 0541 91 E0		        sta (fx_ptr),y
   173 0543 C8			        iny
   174 0544 A9 23		        lda #35
   175 0546 91 E0		        sta (fx_ptr),y
   176 0548 60			        rts
   177
   178 0549			pal_40_20_75:
   179 0549 A0 46		        ldy #$46
   180 054B A9 28		        lda #40
   181 054D 91 E0		        sta (fx_ptr),y
   182 054F C8			        iny
   183 0550 A9 14		        lda #20
   184 0552 91 E0		        sta (fx_ptr),y
   185 0554 C8			        iny
   186 0555 A9 4B		        lda #75
   187 0557 91 E0		        sta (fx_ptr),y
   188 0559 60			        rts
   189
   190 055A			pal_25_35_90:
   191 055A A0 46		        ldy #$46
   192 055C A9 19		        lda #25
   193 055E 91 E0		        sta (fx_ptr),y
   194 0560 C8			        iny
   195 0561 A9 23		        lda #35
   196 0563 91 E0		        sta (fx_ptr),y
   197 0565 C8			        iny
   198 0566 A9 5A		        lda #90
   199 0568 91 E0		        sta (fx_ptr),y
   200 056A 60			        rts
   201
   202 056B			pal_20_55_95:
   203 056B A0 46		        ldy #$46
   204 056D A9 14		        lda #20
   205 056F 91 E0		        sta (fx_ptr),y
   206 0571 C8			        iny
   207 0572 A9 37		        lda #55
   208 0574 91 E0		        sta (fx_ptr),y
   209 0576 C8			        iny
   210 0577 A9 5F		        lda #95
   211 0579 91 E0		        sta (fx_ptr),y
   212 057B 60			        rts
   213
   214 057C			pal_15_65_80:
   215 057C A0 46		        ldy #$46
   216 057E A9 0F		        lda #15
   217 0580 91 E0		        sta (fx_ptr),y
   218 0582 C8			        iny
   219 0583 A9 41		        lda #65
   220 0585 91 E0		        sta (fx_ptr),y
   221 0587 C8			        iny
   222 0588 A9 50		        lda #80
   223 058A 91 E0		        sta (fx_ptr),y
   224 058C 60			        rts
   225
   226 058D			pal_20_80_80:
   227 058D A0 46		        ldy #$46
   228 058F A9 14		        lda #20
   229 0591 91 E0		        sta (fx_ptr),y
   230 0593 C8			        iny
   231 0594 A9 50		        lda #80
   232 0596 91 E0		        sta (fx_ptr),y
   233 0598 C8			        iny
   234 0599 A9 50		        lda #80
   235 059B 91 E0		        sta (fx_ptr),y
   236 059D 60			        rts
   237
   238 059E			pal_40_95_90:
   239 059E A0 46		        ldy #$46
   240 05A0 A9 28		        lda #40
   241 05A2 91 E0		        sta (fx_ptr),y
   242 05A4 C8			        iny
   243 05A5 A9 5F		        lda #95
   244 05A7 91 E0		        sta (fx_ptr),y
   245 05A9 C8			        iny
   246 05AA A9 5A		        lda #90
   247 05AC 91 E0		        sta (fx_ptr),y
   248 05AE 60			        rts
   249
   250 				; ============================================================
   251 				; XDL — matches st2vbxe exactly.
   252 				;
   253 				; Entry 1: 20 blank lines (OVOFF + RPTL)
   254 				; Entry 2: 200 lines overlay (GMON + RPTL + OVADR + END)
   255 				; ============================================================
   256 05AF			xdl:
   257 05AF 24 00		        .word $0024         ; XDLC = OVOFF($04) | RPTL($20)
   258 05B1 13			        .byte 19            ; 20 blank lines
   259
   260 05B2 62 80		        .word $8062         ; XDLC = GMON($02) | RPTL($20)
   261 				                            ;      | OVADR($40) | END($8000)
   262 05B4 C7			        .byte 199           ; 200 lines
   263
   264 				        ; OVADR: 3-byte address + 2-byte step
   265 05B5 00			        .byte <[scr_vbxe&$FFFF]   ; $00
   266 05B6 01			        .byte >[scr_vbxe&$FFFF]   ; $01
   267 05B7 01			        .byte 1                     ; bank 1 ($10000>>16)
   268 05B8 40 01		        .word 320                   ; step = 320 bytes/line
   269 = 000B			xdl_len = *-xdl
   270
   271 				; ============================================================
   272 05BA			        org $02E2
   273 02E2-02E3> 80 04		        .word vbxe_init
