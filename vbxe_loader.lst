mads 2.1.8
vbxe_loader.asm -o:vbxe_loader.xex -l 
Source: vbxe_loader.asm
     1 				; VBXE Overlay Title Screen for Starquake
     2 				; Clean implementation: pre-rendered 8bpp overlay
     3 				; from C64 title screen data.
     4 				;
     5 				; XEX structure:
     6 				;   [this segment: $8000, INIT=vbxe_load]
     7 				;   [game XEX: untouched]
     8 				;   [hook segment: $0400, INIT=hook_init]
     9
    10 				; ---- VBXE registers (base $D640, FX 1.xx) ----
    11 = D640			VBXE      = $D640
    12 = D640			VBXE_VC   = VBXE+$00  ; VIDEO_CONTROL (write) / CORE_VERSION (read)
    13 = D641			VBXE_XA0  = VBXE+$01  ; XDL_ADR0
    14 = D642			VBXE_XA1  = VBXE+$02  ; XDL_ADR1
    15 = D643			VBXE_XA2  = VBXE+$03  ; XDL_ADR2
    16 = D644			VBXE_CSEL = VBXE+$04
    17 = D645			VBXE_PSEL = VBXE+$05
    18 = D646			VBXE_CR   = VBXE+$06
    19 = D647			VBXE_CG   = VBXE+$07
    20 = D648			VBXE_CB   = VBXE+$08
    21 = D65D			MEMAC_A   = VBXE+$1D  ; MEMAC-A bank select + MCE
    22
    23 				; ---- Zero page temporaries ----
    24 = 00FB			ZSRC      = $FB        ; 2 bytes: RLE source pointer
    25 = 00FD			ZDST      = $FD        ; 2 bytes: VRAM dest pointer
    26
    27 				; ---- Constants ----
    28 = 0080			MEMAC_MCE = $80        ; MEMAC CPU enable bit
    29 = 0004			OVL_BANK0 = 4          ; first VRAM bank for overlay ($10000/16K=4)
    30 = 0007			NUM_COLORS = 7
    31 = 0010			VBXE_ID   = $10        ; FX 1.xx core version
    32
    33 				; ===================================================
    34 				; SEGMENT 1: Overlay data loader
    35 				; Loads before the game. INIT decompresses overlay
    36 				; to VBXE VRAM, writes XDL, sets palette.
    37 				; Game segments then overwrite $8000+ — that's fine,
    38 				; the data is already in VRAM.
    39 				; ===================================================
    40
    41 				        org $8000
    42
    43 				; ---- Entry point (called via INIT vector) ----
    44 				vbxe_load
    45 				        ; Detect VBXE at $D640
    46 FFFF> 8000-BAE6> AD 40 +         lda VBXE_VC
    47 8003 C9 10		        cmp #VBXE_ID
    48 8005 F0 01		        beq detected
    49 8007 60			        rts              ; no VBXE, bail
    50
    51 8008			detected
    52 				        ; Disable VBXE during setup
    53 8008 A9 00		        lda #0
    54 800A 8D 40 D6		        sta VBXE_VC
    55
    56 				        ; ---- Write XDL to VRAM $00000 ----
    57 800D A9 80		        lda #MEMAC_MCE+0 ; bank 0
    58 800F 8D 5D D6		        sta MEMAC_A
    59
    60 8012 A2 0C		        ldx #xdl_len-1
    61 8014 BD AA 80		wxdl    lda xdl_data,x
    62 8017 9D 00 40		        sta $4000,x      ; VRAM $00000 via MEMAC
    63 801A CA			        dex
    64 801B 10 F7		        bpl wxdl
    65
    66 				        ; ---- Decompress RLE overlay to VRAM $10000 ----
    67 801D A9 84		        lda #MEMAC_MCE+OVL_BANK0
    68 801F 8D 5D D6		        sta MEMAC_A       ; bank 4 -> VRAM $10000
    69 8022 8D CC 80		        sta cur_bank      ; track in RAM (register is write-only)
    70
    71 8025 A9 CE		        lda #<rle_data
    72 8027 85 FB		        sta ZSRC
    73 8029 A9 80		        lda #>rle_data
    74 802B 85 FC		        sta ZSRC+1
    75 802D A9 00		        lda #$00
    76 802F 85 FD		        sta ZDST
    77 8031 A9 40		        lda #$40
    78 8033 85 FE		        sta ZDST+1        ; dest = $4000 (MEMAC window start)
    79
    80 8035 A0 00		dloop   ldy #0
    81 8037 B1 FB		        lda (ZSRC),y      ; count
    82 8039 F0 3B		        beq ddone         ; 0 = end marker
    83 803B AA			        tax               ; X = run length
    84 803C C8			        iny
    85 803D B1 FB		        lda (ZSRC),y      ; value
    86 803F 8D CD 80		        sta fill_val      ; save in RAM (A gets trashed by bank switch)
    87
    88 				        ; Advance ZSRC by 2
    89 8042 18			        clc
    90 8043 A5 FB		        lda ZSRC
    91 8045 69 02		        adc #2
    92 8047 85 FB		        sta ZSRC
    93 8049 90 02		        bcc nosrhi
    94 804B E6 FC		        inc ZSRC+1
    95 804D			nosrhi
    96
    97 804D AD CD 80		wloop   lda fill_val      ; reload fill value each iteration
    98 8050 A0 00		        ldy #0
    99 8052 91 FD		        sta (ZDST),y
   100
   101 				        ; Advance ZDST by 1
   102 8054 E6 FD		        inc ZDST
   103 8056 D0 02		        bne nodshi
   104 8058 E6 FE		        inc ZDST+1
   105 805A			nodshi
   106 				        ; Check if ZDST reached $8000 (end of 16K MEMAC window)
   107 805A A5 FE		        lda ZDST+1
   108 805C C9 80		        cmp #$80
   109 805E 90 11		        bcc nobnk
   110
   111 				        ; Bank switch: reset window pointer, advance bank
   112 8060 A9 00		        lda #$00
   113 8062 85 FD		        sta ZDST
   114 8064 A9 40		        lda #$40
   115 8066 85 FE		        sta ZDST+1
   116 8068 EE CC 80		        inc cur_bank
   117 806B AD CC 80		        lda cur_bank
   118 806E 8D 5D D6		        sta MEMAC_A
   119
   120 8071 CA			nobnk   dex
   121 8072 D0 D9		        bne wloop
   122 8074 F0 BF		        beq dloop         ; next RLE pair
   123
   124 8076			ddone
   125 				        ; ---- Disable MEMAC ----
   126 8076 A9 00		        lda #0
   127 8078 8D 5D D6		        sta MEMAC_A
   128
   129 				        ; ---- Set palette (palette 1, colors 1-7) ----
   130 807B A9 01		        lda #1
   131 807D 8D 44 D6		        sta VBXE_CSEL     ; start at color index 1
   132 8080 8D 45 D6		        sta VBXE_PSEL     ; palette 1
   133
   134 8083 A2 00		        ldx #0
   135 8085 BD B7 80		ploop   lda pal_data,x
   136 8088 8D 46 D6		        sta VBXE_CR
   137 808B E8			        inx
   138 808C BD B7 80		        lda pal_data,x
   139 808F 8D 47 D6		        sta VBXE_CG
   140 8092 E8			        inx
   141 8093 BD B7 80		        lda pal_data,x
   142 8096 8D 48 D6		        sta VBXE_CB       ; auto-advances CSEL
   143 8099 E8			        inx
   144 809A E0 15		        cpx #NUM_COLORS*3
   145 809C 90 E7		        bcc ploop
   146
   147 				        ; ---- Set XDL address to $00000 ----
   148 809E A9 00		        lda #0
   149 80A0 8D 41 D6		        sta VBXE_XA0
   150 80A3 8D 42 D6		        sta VBXE_XA1
   151 80A6 8D 43 D6		        sta VBXE_XA2
   152
   153 				        ; Don't enable VIDEO_CONTROL yet.
   154 				        ; The hook code enables it at title screen entry.
   155 80A9 60			        rts
   156
   157 				; ---- XDL data (13 bytes) ----
   158 80AA			xdl_data
   159 80AA 24 00 17 62 88 BF +         ins 'data/xdl.bin'
   160 = 000D			xdl_len = *-xdl_data
   161
   162 				; ---- Palette data (21 bytes) ----
   163 80B7			pal_data
   164 80B7 00 00 00 FF FF FF +         ins 'data/palette.bin'
   165
   166 				; ---- Variables ----
   167 80CC 00			cur_bank  .byte 0
   168 80CD 00			fill_val  .byte 0
   169
   170 				; ---- RLE-compressed overlay (14873 bytes) ----
   171 80CE			rle_data
   172 80CE FF 01 6C 01 E9 04 +         ins 'data/overlay_rle.bin'
   173
   174 = BAE7			endload = *
   175 				        .print "Loader segment: $8000-", endload-1, " (", endload-$8000, " bytes)"
   175 				Loader segment: $8000-$BAE6 ($3AE7 bytes)
   176
   177 				; INIT vector for this segment
   178 BAE7			        org $02E2
   179 02E2-02E3> 00 80		        .word vbxe_load
