mads 2.1.8
vbxe_loader.asm -o:vbxe_loader.xex -l 
Source: vbxe_loader.asm
     1 				; VBXE Overlay Loader for Starquake
     2 				;
     3 				; Loads BEFORE the game. INIT decompresses overlay to
     4 				; VBXE VRAM, writes XDL, sets palette. Game segments
     5 				; then overwrite $8000+ — data is already in VRAM.
     6 				;
     7 				; The game's VBI is patched by the Python build script
     8 				; (build_vbxe.py) to auto-detect title screen ($AA=0)
     9 				; and enable/disable VBXE accordingly. No hook segment
    10 				; at $0400 needed.
    11
    12 = D640			VBXE      = $D640
    13 = D640			VBXE_VC   = VBXE+$00
    14 = D641			VBXE_XA0  = VBXE+$01
    15 = D642			VBXE_XA1  = VBXE+$02
    16 = D643			VBXE_XA2  = VBXE+$03
    17 = D644			VBXE_CSEL = VBXE+$04
    18 = D645			VBXE_PSEL = VBXE+$05
    19 = D646			VBXE_CR   = VBXE+$06
    20 = D647			VBXE_CG   = VBXE+$07
    21 = D648			VBXE_CB   = VBXE+$08
    22 = D65D			MEMAC_A   = VBXE+$1D
    23
    24 = 00FB			ZSRC      = $FB
    25 = 00FD			ZDST      = $FD
    26
    27 = 0080			MEMAC_MCE = $80
    28 = 0004			OVL_BANK0 = 4
    29 = 0007			NUM_COLORS = 7
    30 = 0010			VBXE_ID   = $10
    31
    32 				        org $8000
    33
    34 				vbxe_load
    35 FFFF> 8000-BAE6> AD 40 +         lda VBXE_VC
    36 8003 C9 10		        cmp #VBXE_ID
    37 8005 F0 01		        beq detected
    38 8007 60			        rts
    39
    40 8008			detected
    41 8008 A9 00		        lda #0
    42 800A 8D 40 D6		        sta VBXE_VC
    43
    44 				        ; Write XDL to VRAM $00000
    45 800D A9 80		        lda #MEMAC_MCE+0
    46 800F 8D 5D D6		        sta MEMAC_A
    47 8012 A2 0C		        ldx #xdl_len-1
    48 8014 BD AA 80		wxdl    lda xdl_data,x
    49 8017 9D 00 40		        sta $4000,x
    50 801A CA			        dex
    51 801B 10 F7		        bpl wxdl
    52
    53 				        ; Decompress RLE overlay to VRAM $10000
    54 801D A9 84		        lda #MEMAC_MCE+OVL_BANK0
    55 801F 8D 5D D6		        sta MEMAC_A
    56 8022 8D CC 80		        sta cur_bank
    57
    58 8025 A9 CE		        lda #<rle_data
    59 8027 85 FB		        sta ZSRC
    60 8029 A9 80		        lda #>rle_data
    61 802B 85 FC		        sta ZSRC+1
    62 802D A9 00		        lda #$00
    63 802F 85 FD		        sta ZDST
    64 8031 A9 40		        lda #$40
    65 8033 85 FE		        sta ZDST+1
    66
    67 8035 A0 00		dloop   ldy #0
    68 8037 B1 FB		        lda (ZSRC),y
    69 8039 F0 3B		        beq ddone
    70 803B AA			        tax
    71 803C C8			        iny
    72 803D B1 FB		        lda (ZSRC),y
    73 803F 8D CD 80		        sta fill_val
    74
    75 8042 18			        clc
    76 8043 A5 FB		        lda ZSRC
    77 8045 69 02		        adc #2
    78 8047 85 FB		        sta ZSRC
    79 8049 90 02		        bcc nosrhi
    80 804B E6 FC		        inc ZSRC+1
    81 804D			nosrhi
    82
    83 804D AD CD 80		wloop   lda fill_val
    84 8050 A0 00		        ldy #0
    85 8052 91 FD		        sta (ZDST),y
    86
    87 8054 E6 FD		        inc ZDST
    88 8056 D0 02		        bne nodshi
    89 8058 E6 FE		        inc ZDST+1
    90 805A			nodshi
    91 805A A5 FE		        lda ZDST+1
    92 805C C9 80		        cmp #$80
    93 805E 90 11		        bcc nobnk
    94
    95 8060 A9 00		        lda #$00
    96 8062 85 FD		        sta ZDST
    97 8064 A9 40		        lda #$40
    98 8066 85 FE		        sta ZDST+1
    99 8068 EE CC 80		        inc cur_bank
   100 806B AD CC 80		        lda cur_bank
   101 806E 8D 5D D6		        sta MEMAC_A
   102
   103 8071 CA			nobnk   dex
   104 8072 D0 D9		        bne wloop
   105 8074 F0 BF		        beq dloop
   106
   107 8076			ddone
   108 8076 A9 00		        lda #0
   109 8078 8D 5D D6		        sta MEMAC_A
   110
   111 				        ; Set palette (palette 1, colors 1-7)
   112 807B A9 01		        lda #1
   113 807D 8D 44 D6		        sta VBXE_CSEL
   114 8080 8D 45 D6		        sta VBXE_PSEL
   115
   116 8083 A2 00		        ldx #0
   117 8085 BD B7 80		ploop   lda pal_data,x
   118 8088 8D 46 D6		        sta VBXE_CR
   119 808B E8			        inx
   120 808C BD B7 80		        lda pal_data,x
   121 808F 8D 47 D6		        sta VBXE_CG
   122 8092 E8			        inx
   123 8093 BD B7 80		        lda pal_data,x
   124 8096 8D 48 D6		        sta VBXE_CB
   125 8099 E8			        inx
   126 809A E0 15		        cpx #NUM_COLORS*3
   127 809C 90 E7		        bcc ploop
   128
   129 				        ; Set XDL address
   130 809E A9 00		        lda #0
   131 80A0 8D 41 D6		        sta VBXE_XA0
   132 80A3 8D 42 D6		        sta VBXE_XA1
   133 80A6 8D 43 D6		        sta VBXE_XA2
   134
   135 				        ; Don't enable VIDEO_CONTROL — the patched VBI does it
   136 80A9 60			        rts
   137
   138 80AA			xdl_data
   139 80AA 24 00 17 62 88 BF +         ins 'data/xdl.bin'
   140 = 000D			xdl_len = *-xdl_data
   141
   142 80B7			pal_data
   143 80B7 00 00 00 FF FF FF +         ins 'data/palette.bin'
   144
   145 80CC 00			cur_bank  .byte 0
   146 80CD 00			fill_val  .byte 0
   147
   148 80CE			rle_data
   149 80CE FF 01 6C 01 E9 04 +         ins 'data/overlay_rle.bin'
   150
   151 BAE7			        org $02E2
   152 02E2-02E3> 00 80		        .word vbxe_load
