mads 2.1.8
vbxe_hook.asm -o:vbxe_hook.xex -l 
Source: vbxe_hook.asm
     1 				; VBXE Hook Code for Starquake
     2 				; Loads AFTER the game. INIT patches the game
     3 				; to enable VBXE overlay on title screen entry.
     4 				;
     5 				; Hook chain:
     6 				;   INIT → patches relocator JMP at $BC1A
     7 				;   relocator runs → JMPs to postrel
     8 				;   postrel → patches $0BBF with JMP tsetup
     9 				;   game reaches title screen → $0BBF fires
    10 				;   tsetup → enables VBXE, continues game
    11
    12 = D640			VBXE_VC    = $D640
    13 = 0010			VBXE_ID    = $10
    14
    15 = 0222			VVBLKI     = $0222
    16 = 05B9			GAME_ENTRY = $05B9
    17 = 0BD6			GAME_VBI   = $0BD6
    18 = BC1A			RELOC_JMP  = $BC1A
    19 = 0BBF			HOOK_ADDR  = $0BBF
    20 = 0B81			HOOK_CONT  = $0B81
    21 = 022F			SDMCTL     = $022F
    22
    23 				        org $0400
    24
    25 				; ---- INIT (called at XEX load, after game loaded) ----
    26 				hook_init
    27 				        ; Only patch if VBXE was detected (check core ver)
    28 FFFF> 0400-0432> AD 40 +         lda VBXE_VC
    29 0403 C9 10		        cmp #VBXE_ID
    30 0405 F0 01		        beq dodet
    31 0407 60			        rts
    32 0408			dodet
    33 				        ; Patch relocator JMP at $BC1A to go to postrel
    34 0408 A9 13		        lda #<postrel
    35 040A 8D 1B BC		        sta RELOC_JMP+1
    36 040D A9 04		        lda #>postrel
    37 040F 8D 1C BC		        sta RELOC_JMP+2
    38 0412 60			        rts
    39
    40 				; ---- POST-RELOC (game relocated, now in runtime addresses) ----
    41 0413			postrel
    42 				        ; Patch title-ready point with JMP tsetup
    43 0413 A9 4C		        lda #$4C          ; JMP opcode
    44 0415 8D BF 0B		        sta HOOK_ADDR
    45 0418 A9 25		        lda #<tsetup
    46 041A 8D C0 0B		        sta HOOK_ADDR+1
    47 041D A9 04		        lda #>tsetup
    48 041F 8D C1 0B		        sta HOOK_ADDR+2
    49 0422 4C B9 05		        jmp GAME_ENTRY
    50
    51 				; ---- TITLE SETUP (title screen is ready to display) ----
    52 0425			tsetup
    53 				        ; Enable VBXE XDL
    54 0425 A9 01		        lda #$01
    55 0427 8D 40 D6		        sta VBXE_VC
    56
    57 				        ; Do the original code at $0BBF:
    58 				        ;   LDA #$3A / CLI / BNE $0B81
    59 042A A9 3A		        lda #$3A
    60 042C 8D 2F 02		        sta SDMCTL
    61 042F 58			        cli
    62 0430 4C 81 0B		        jmp HOOK_CONT
    63
    64 				        .if * > $0580
    65 				        .error "Hook segment exceeds $0580!"
    66 				        .endif
    67
    68 				; INIT vector for this segment
    69 0433			        org $02E2
    70 02E2-02E3> 00 04		        .word hook_init
