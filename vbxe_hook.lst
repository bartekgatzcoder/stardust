mads 2.1.8
vbxe_hook.asm -o:vbxe_hook.xex -l 
Source: vbxe_hook.asm
     1 				; VBXE Hook Code for Starquake
     2 				; Loads AFTER the game. INIT patches the game
     3 				; to enable VBXE overlay on title screen entry
     4 				; and disable it on title screen exit.
     5 				;
     6 				; Hook chain:
     7 				;   INIT -> patches relocator JMP at $BC1A
     8 				;   relocator -> postrel
     9 				;   postrel -> patches $0BBF (title entry) and $36AC (title exit)
    10 				;   title screen entry ($0BBF) -> tsetup: enable VBXE
    11 				;   title screen exit  ($36AC) -> tdone:  disable VBXE
    12
    13 = D640			VBXE_VC    = $D640
    14 = 0010			VBXE_ID    = $10
    15
    16 = 022F			SDMCTL     = $022F
    17 = 05B9			GAME_ENTRY = $05B9
    18 = BC1A			RELOC_JMP  = $BC1A
    19 = 0BBF			HOOK_ADDR  = $0BBF      ; title entry point
    20 = 0B81			HOOK_CONT  = $0B81
    21 = 36AC			EXIT_ADDR  = $36AC      ; title exit point
    22 = 36B0			EXIT_CONT  = $36B0      ; continue after 3 patched bytes
    23
    24 				        org $0400
    25
    26 				; ---- INIT (called at XEX load) ----
    27 				hook_init
    28 FFFF> 0400-044D> AD 40 +         lda VBXE_VC
    29 0403 C9 10		        cmp #VBXE_ID
    30 0405 F0 01		        beq dodet
    31 0407 60			        rts
    32 0408			dodet
    33 0408 A9 13		        lda #<postrel
    34 040A 8D 1B BC		        sta RELOC_JMP+1
    35 040D A9 04		        lda #>postrel
    36 040F 8D 1C BC		        sta RELOC_JMP+2
    37 0412 60			        rts
    38
    39 				; ---- POST-RELOC ----
    40 0413			postrel
    41 				        ; Patch title entry: $0BBF -> JMP tsetup
    42 0413 A9 4C		        lda #$4C
    43 0415 8D BF 0B		        sta HOOK_ADDR
    44 0418 A9 34		        lda #<tsetup
    45 041A 8D C0 0B		        sta HOOK_ADDR+1
    46 041D A9 04		        lda #>tsetup
    47 041F 8D C1 0B		        sta HOOK_ADDR+2
    48
    49 				        ; Patch title exit: $36AC -> JMP tdone
    50 0422 A9 4C		        lda #$4C
    51 0424 8D AC 36		        sta EXIT_ADDR
    52 0427 A9 42		        lda #<tdone
    53 0429 8D AD 36		        sta EXIT_ADDR+1
    54 042C A9 04		        lda #>tdone
    55 042E 8D AE 36		        sta EXIT_ADDR+2
    56
    57 0431 4C B9 05		        jmp GAME_ENTRY
    58
    59 				; ---- TITLE ENTRY (enables VBXE overlay) ----
    60 0434			tsetup
    61 0434 A9 01		        lda #$01
    62 0436 8D 40 D6		        sta VBXE_VC       ; XDL enabled
    63
    64 				        ; Original code at $0BBF:
    65 				        ;   LDA #$3A / CLI / BNE $0B81
    66 0439 A9 3A		        lda #$3A
    67 043B 8D 2F 02		        sta SDMCTL
    68 043E 58			        cli
    69 043F 4C 81 0B		        jmp HOOK_CONT
    70
    71 				; ---- TITLE EXIT (disables VBXE overlay) ----
    72 0442			tdone
    73 0442 A9 00		        lda #$00
    74 0444 8D 40 D6		        sta VBXE_VC       ; XDL disabled
    75
    76 				        ; Original code at $36AC-$36AF:
    77 				        ;   CLI / PHA / LDA #$00
    78 0447 58			        cli
    79 0448 48			        pha
    80 0449 A9 00		        lda #$00
    81 044B 4C B0 36		        jmp EXIT_CONT     ; continue at $36B0
    82
    83 				        .if * > $0580
    84 				        .error "Hook segment exceeds $0580!"
    85 				        .endif
    86
    87 				; INIT vector
    88 044E			        org $02E2
    89 02E2-02E3> 00 04		        .word hook_init
