mads 2.1.8
vbxe_hook.asm -o:vbxe_hook.xex -l 
Source: vbxe_hook.asm
     1 				; VBXE Hook Code for Starquake
     2 				; Loads AFTER the game. INIT patches the game
     3 				; to enable VBXE overlay on title screen entry
     4 				; and disable it when the next screen starts.
     5 				;
     6 				; Hook points (all in post-relocation runtime space):
     7 				;   $0BBF — title screen is ready to display
     8 				;   $20F2 — title screen done, next screen init begins
     9 				;
    10 				; Both fire-to-start and music-end paths converge at $20F2
    11 				; before calling the next-screen initializer at $2639.
    12
    13 = D640			VBXE_VC    = $D640
    14 = 0010			VBXE_ID    = $10
    15
    16 = 022F			SDMCTL     = $022F
    17 = 05B9			GAME_ENTRY = $05B9
    18 = BC1A			RELOC_JMP  = $BC1A
    19
    20 				; Title entry hook
    21 = 0BBF			HOOK_ADDR  = $0BBF       ; LDA #$3A / CLI / BNE $0B81
    22 = 0B81			HOOK_CONT  = $0B81
    23
    24 				; Title exit hook — next screen init
    25 				; Original: LDX #$00 / JSR $2639 / LDA #$86 / JMP $3611
    26 = 20F2			EXIT_ADDR  = $20F2
    27 = 20F7			EXIT_CONT  = $20F7       ; first intact instruction after 3 patched bytes
    28
    29 				        org $0400
    30
    31 				; ---- INIT (called at XEX load) ----
    32 				hook_init
    33 FFFF> 0400-044E> AD 40 +         lda VBXE_VC
    34 0403 C9 10		        cmp #VBXE_ID
    35 0405 F0 01		        beq dodet
    36 0407 60			        rts
    37 0408			dodet
    38 0408 A9 13		        lda #<postrel
    39 040A 8D 1B BC		        sta RELOC_JMP+1
    40 040D A9 04		        lda #>postrel
    41 040F 8D 1C BC		        sta RELOC_JMP+2
    42 0412 60			        rts
    43
    44 				; ---- POST-RELOC ----
    45 0413			postrel
    46 				        ; Patch title entry: $0BBF -> JMP tsetup
    47 0413 A9 4C		        lda #$4C
    48 0415 8D BF 0B		        sta HOOK_ADDR
    49 0418 A9 34		        lda #<tsetup
    50 041A 8D C0 0B		        sta HOOK_ADDR+1
    51 041D A9 04		        lda #>tsetup
    52 041F 8D C1 0B		        sta HOOK_ADDR+2
    53
    54 				        ; Patch next-screen init: $20F2 -> JMP tdone
    55 0422 A9 4C		        lda #$4C
    56 0424 8D F2 20		        sta EXIT_ADDR
    57 0427 A9 42		        lda #<tdone
    58 0429 8D F3 20		        sta EXIT_ADDR+1
    59 042C A9 04		        lda #>tdone
    60 042E 8D F4 20		        sta EXIT_ADDR+2
    61
    62 0431 4C B9 05		        jmp GAME_ENTRY
    63
    64 				; ---- TITLE ENTRY (enables VBXE overlay) ----
    65 0434			tsetup
    66 0434 A9 01		        lda #$01
    67 0436 8D 40 D6		        sta VBXE_VC
    68
    69 				        ; Original code at $0BBF:
    70 0439 A9 3A		        lda #$3A
    71 043B 8D 2F 02		        sta SDMCTL
    72 043E 58			        cli
    73 043F 4C 81 0B		        jmp HOOK_CONT
    74
    75 				; ---- TITLE EXIT (disables VBXE overlay) ----
    76 				; Replaces $20F2-$20F4 (LDX #$00 / JSR opcode).
    77 				; Executes the overwritten instructions, then
    78 				; continues at $20F7 (LDA #$86 / JMP $3611).
    79 0442			tdone
    80 0442 A9 00		        lda #$00
    81 0444 8D 40 D6		        sta VBXE_VC       ; XDL disabled
    82
    83 0447 A2 00		        ldx #$00          ; original $20F2
    84 0449 20 39 26		        jsr $2639         ; original $20F4
    85 044C 4C F7 20		        jmp EXIT_CONT     ; -> $20F7
    86
    87 				        .if * > $0580
    88 				        .error "Hook segment exceeds $0580!"
    89 				        .endif
    90
    91 				; INIT vector
    92 044F			        org $02E2
    93 02E2-02E3> 00 04		        .word hook_init
